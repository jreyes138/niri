#!/bin/bash
# y — wrapper that opens yazi and cds to the last directory on exit
# Based on the official yazi wrapper script
tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
cwd="$(pwd)"
yazi "$@" --cwd-file="$tmp"
if cwd="$(cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
    cd -- "$cwd"
fi
rm -f -- "$tmp"