#!/bin/bash
# niri-theme — switch between color themes for niri + wezterm + waybar + system
# Usage: niri-theme <theme-name>
# Themes: gruvbox-dark, catppuccin-mocha, nord, tokyo-night
#         (partial matches allowed: gruvbox, catppuccin, mocha, nord, tokyo)

set -euo pipefail

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}"
NIRI_CONFIG="$CONFIG_DIR/niri/config.kdl"
WEZTERM_CONFIG="$HOME/.wezterm.lua"
WAYBAR_CSS="$CONFIG_DIR/waybar/style.css"
FUZZEL_INI="$CONFIG_DIR/fuzzel/fuzzel.ini"
MAKO_CONF="$CONFIG_DIR/mako/config"
SWAYLOCK_CONF="$CONFIG_DIR/swaylock/config"
WLOGOUT_CSS="$CONFIG_DIR/wlogout/style.css"
WALLPAPER_DIR="$HOME/Pictures/wallpapers"

# ── Theme definitions ─────────────────────────────────────────────────────
declare -A THEMES
THEME_NAMES="gruvbox-dark catppuccin-mocha nord tokyo-night"

# Each theme defines:
#   bg        - main background
#   bg_alt    - secondary background (panels, borders)
#   fg        - main foreground text
#   fg_dim    - dimmed text
#   accent    - accent/highlight color
#   green     - success/battery
#   yellow    - warning/brightness
#   red       - critical/danger
#   blue      - info/bluetooth
#   purple    - power profiles
#   wezterm   - wezterm color_scheme name
#   gtk_theme - GTK theme (gsettings)
#   icon_theme - icon theme (gsettings)
#   wallpaper - wallpaper filename in ~/Pictures/wallpapers

# ── Gruvbox Dark ───────────────────────────────────────────────────────────
declare -A gruvbox_dark=(
    [bg]="#282828" [bg_alt]="#3c3836" [bg_dark]="#1d2021"
    [fg]="#ebdbb2" [fg_dim]="#a89984"
    [accent]="#d79921" [green]="#689d6a" [yellow]="#fabd2f"
    [red]="#fb4934" [blue]="#458588" [purple]="#b16286"
    [wezterm]="Gruvbox Dark"
    [gtk_theme]="adw-gtk3-dark" [icon_theme]="Gruvbox-Plus-Dark"
    [wallpaper]="gruvbox-dark.png"
)

# ── Catppuccin Mocha ───────────────────────────────────────────────────────
declare -A catppuccin_mocha=(
    [bg]="#1e1e2e" [bg_alt]="#313244" [bg_dark]="#181825"
    [fg]="#cdd6f4" [fg_dim]="#a6adc8"
    [accent]="#cba6f7" [green]="#a6e3a1" [yellow]="#f9e2af"
    [red]="#f38ba8" [blue]="#89b4fa" [purple]="#cba6f7"
    [wezterm]="Catppuccin Mocha"
    [gtk_theme]="adw-gtk3-dark" [icon_theme]="Gruvbox-Plus-Dark"
    [wallpaper]="catppuccin-mocha.png"
)

# ── Nord ──────────────────────────────────────────────────────────────────
declare -A nord=(
    [bg]="#2e3440" [bg_alt]="#3b4252" [bg_dark]="#1e222a"
    [fg]="#e5e9f0" [fg_dim]="#81a1c1"
    [accent]="#88c0d0" [green]="#a3be8c" [yellow]="#ebcb8b"
    [red]="#bf616a" [blue]="#81a1c1" [purple]="#b48ead"
    [wezterm]="Nord (Gogh)"
    [gtk_theme]="adw-gtk3-dark" [icon_theme]="Gruvbox-Plus-Dark"
    [wallpaper]="nord.png"
)

# ── Tokyo Night ────────────────────────────────────────────────────────────
declare -A tokyo_night=(
    [bg]="#1a1b26" [bg_alt]="#24283b" [bg_dark]="#16161e"
    [fg]="#c0caf5" [fg_dim]="#565f89"
    [accent]="#7aa2f7" [green]="#9ece6a" [yellow]="#e0af68"
    [red]="#f7768e" [blue]="#7aa2f7" [purple]="#bb9af7"
    [wezterm]="Tokyo Night"
    [gtk_theme]="adw-gtk3-dark" [icon_theme]="Gruvbox-Plus-Dark"
    [wallpaper]="tokyo-night.png"
)

# ── Helper: get theme by name (partial match) ──────────────────────────────
get_theme() {
    local input="$1"
    case "$input" in
        *gruvbox*|*Gruvbox*) echo "gruvbox_dark" ;;
        *catppuccin*|*mocha*|*Catppuccin*|*Mocha*) echo "catppuccin_mocha" ;;
        *nord*|*Nord*) echo "nord" ;;
        *tokyo*|*Tokyo*) echo "tokyo_night" ;;
        *) return 1 ;;
    esac
}

# ── Color format helpers ──────────────────────────────────────────────────
# Convert #rrggbb to hex without #
strip_hash() { echo "${1#\#}"; }

# Convert #rrggbb to rgba(r,g,b,a) for CSS
hex_to_rgba() {
    local hex="$1" alpha="${2:-1.0}"
    local r=$((16#${hex:1:2}))
    local g=$((16#${hex:3:2}))
    local b=$((16#${hex:5:2}))
    echo "rgba($r, $g, $b, $alpha)"
}

# ── Apply theme to niri config ─────────────────────────────────────────────
apply_niri() {
    local -n t="$1"
    local config="$NIRI_CONFIG"
    local tmp; tmp=$(mktemp)

    # Replace focus-ring, border colors, and background-color
    sed -e "s/active-color \"#[0-9a-fA-F]*\"/active-color \"${t[accent]}\"/g" \
        -e "s/inactive-color \"#[0-9a-fA-F]*\"/inactive-color \"${t[bg_alt]}\"/g" \
        -e "s/urgent-color \"#[0-9a-fA-F]*\"/urgent-color \"${t[red]}\"/g" \
        -e "s/background-color \"[^\"]*\"/background-color \"${t[bg_dark]}\"/" \
        "$config" > "$tmp"

    mv "$tmp" "$config"
}

# ── Apply theme to wezterm ─────────────────────────────────────────────────
apply_wezterm() {
    local -n t="$1"
    local config="$WEZTERM_CONFIG"
    local tmp; tmp=$(mktemp)

    # Replace the color_scheme line
    sed "s/color_scheme = \"[^\"]*\"/color_scheme = \"${t[wezterm]}\"/" \
        "$config" > "$tmp"

    mv "$tmp" "$config"
}

# ── Apply theme to waybar CSS ───────────────────────────────────────────────
apply_waybar() {
    local -n t="$1"

    cat > "$WAYBAR_CSS" << WAYBAR_EOF
/* Auto-generated by niri-theme — do not edit manually */
* {
    font-family: "JetBrains Mono", "FiraCode Nerd Font", monospace;
    font-size: 12px;
}

window#waybar {
    background-color: transparent;
    color: ${t[fg]};
    border-bottom: none;
}

#workspaces button {
    padding: 0 8px;
    background-color: transparent;
    color: ${t[fg_dim]};
    border-radius: 6px;
    margin: 2px 1px;
}

#workspaces button.active {
    background-color: $(hex_to_rgba "${t[accent]}" 0.85);
    color: ${t[bg]};
    font-weight: bold;
}

#workspaces button.urgent {
    background-color: $(hex_to_rgba "${t[red]}" 0.85);
    color: ${t[bg]};
}

#workspaces button:hover {
    background-color: $(hex_to_rgba "${t[bg_alt]}" 0.85);
    color: ${t[fg]};
}

#clock {
    background-color: $(hex_to_rgba "${t[bg_alt]}" 0.85);
    color: ${t[accent]};
    padding: 0 10px;
    border-radius: 6px;
    margin: 2px 1px;
}

#network {
    background-color: $(hex_to_rgba "${t[bg_alt]}" 0.85);
    color: ${t[blue]};
    padding: 0 8px;
    border-radius: 6px;
    margin: 2px 1px;
}

#bluetooth {
    background-color: $(hex_to_rgba "${t[bg_alt]}" 0.85);
    color: ${t[blue]};
    padding: 0 8px;
    border-radius: 6px;
    margin: 2px 1px;
}

#bluetooth.connected {
    color: ${t[green]};
}

#pulseaudio {
    background-color: $(hex_to_rgba "${t[bg_alt]}" 0.85);
    color: ${t[green]};
    padding: 0 10px;
    border-radius: 6px;
    margin: 2px 1px;
}

#backlight {
    background-color: $(hex_to_rgba "${t[bg_alt]}" 0.85);
    color: ${t[yellow]};
    padding: 0 10px;
    border-radius: 6px;
    margin: 2px 1px;
}

#battery {
    background-color: $(hex_to_rgba "${t[bg_alt]}" 0.85);
    color: ${t[green]};
    padding: 0 10px;
    border-radius: 6px;
    margin: 2px 1px;
}

#battery.warning {
    color: ${t[yellow]};
}

#battery.critical {
    color: ${t[red]};
}

#battery.charging {
    color: ${t[green]};
}

#power-profiles-daemon {
    background-color: $(hex_to_rgba "${t[bg_alt]}" 0.85);
    color: ${t[purple]};
    padding: 0 8px;
    border-radius: 6px;
    margin: 2px 1px;
}

#power-profiles-daemon.balanced {
    color: ${t[accent]};
}

#power-profiles-daemon.performance {
    color: ${t[red]};
}

#power-profiles-daemon.power-saver {
    color: ${t[green]};
}

#tray {
    background-color: $(hex_to_rgba "${t[bg_alt]}" 0.85);
    padding: 0 6px;
    border-radius: 6px;
    margin: 2px 1px;
}

#tray menu {
    background-color: $(hex_to_rgba "${t[bg]}" 0.95);
    color: ${t[fg]};
    border: 1px solid ${t[bg_alt]};
    border-radius: 6px;
}
WAYBAR_EOF
}

# ── Apply theme to fuzzel ──────────────────────────────────────────────────
apply_fuzzel() {
    local -n t="$1"

    cat > "$FUZZEL_INI" << FUZZEL_EOF
[main]
font=JetBrains Mono:size=12
prompt="❯ "
icon-theme=${t[icon_theme]}
terminal=wezterm -e
lines=15
width=40
horizontal-pad=12
vertical-pad=12
inner-pad=4

[colors]
background=$(strip_hash "${t[bg]}")f0
text=$(strip_hash "${t[fg]}")ff
match=$(strip_hash "${t[accent]}")ff
selection=$(strip_hash "${t[bg_alt]}")ff
selection-text=$(strip_hash "${t[fg]}")ff
border=$(strip_hash "${t[accent]}")ff
selection-match=$(strip_hash "${t[accent]}")ff

[border]
width=2
radius=8
FUZZEL_EOF
}

# ── Apply theme to mako ─────────────────────────────────────────────────────
apply_mako() {
    local -n t="$1"

    cat > "$MAKO_CONF" << MAKO_EOF
# Auto-generated by niri-theme
font=JetBrains Mono 12
background-color=${t[bg]}
text-color=${t[fg]}
border-color=${t[accent]}
border-size=2
border-radius=8
margin=10
padding=10
width=400
height=100
default-timeout=5000
ignore-timeout=false

[urgency=low]
border-color=${t[green]}
default-timeout=3000

[urgency=normal]
border-color=${t[accent]}
default-timeout=5000

[urgency=critical]
border-color=${t[red]}
default-timeout=0
background-color=${t[bg_dark]}
text-color=${t[red]}
MAKO_EOF
}

# ── Apply theme to swaylock ─────────────────────────────────────────────────
apply_swaylock() {
    local -n t="$1"

    cat > "$SWAYLOCK_CONF" << SWAYLOCK_EOF
# Auto-generated by niri-theme

ignore-empty-password
show-failed-attempts

color=${t[bg]}
inside-color=${t[bg]}
ring-color=${t[bg_alt]}
key-hl-color=${t[accent]}
bs-hl-color=${t[red]}
inside-ver-color=${t[blue]}
ring-ver-color=${t[blue]}
inside-wrong-color=${t[red]}
ring-wrong-color=${t[red]}
line-color=${t[bg]}
separator-color=${t[bg]}
text-color=${t[fg]}
text-caps-lock-color=${t[accent]}

indicator-radius=100
indicator-thickness=6
font=JetBrains Mono
SWAYLOCK_EOF
}

# ── Generate per-theme wlogout SVG icons ────────────────────────────────────
WLOGOUT_ICON_DIR="${HOME}/.local/share/wlogout/icons"

gen_wlogout_icons() {
    local -n t="$1"
    mkdir -p "$WLOGOUT_ICON_DIR"

    # Lock icon — padlock shape (uses blue)
    cat > "$WLOGOUT_ICON_DIR/lock.svg" << IEOF
<svg height="16px" viewBox="0 0 16 16" width="16px" xmlns="http://www.w3.org/2000/svg">
    <path d="m 5 7 v -2 c 0 -1.65625 1.34375 -3 3 -3 s 3 1.34375 3 3 v 2 m -7 0 h 8 v 7 h -8 z m 4 3 v 2" fill="none" stroke="${t[blue]}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
</svg>
IEOF

    # Logout icon — door with arrow (uses accent)
    cat > "$WLOGOUT_ICON_DIR/logout.svg" << IEOF
<svg height="16px" viewBox="0 0 16 16" width="16px" xmlns="http://www.w3.org/2000/svg">
    <path d="m 7 1 h -4 c -0.554688 0 -1 0.445312 -1 1 v 12 c 0 0.554688 0.445312 1 1 1 h 4 m 0 -13 h 4 c 0.554688 0 1 0.445312 1 1 v 12 c 0 0.554688 -0.445312 1 -1 1 h -4" fill="none" stroke="${t[accent]}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="m 10 5 l 4 3 l -4 3 m -7 -3 h 7" fill="none" stroke="${t[accent]}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
</svg>
IEOF

    # Shutdown icon — power symbol (uses red)
    cat > "$WLOGOUT_ICON_DIR/shutdown.svg" << IEOF
<svg height="16px" viewBox="0 0 16 16" width="16px" xmlns="http://www.w3.org/2000/svg">
    <path d="m 8 0 c -0.550781 0 -1 0.449219 -1 1 v 5 c 0 0.550781 0.449219 1 1 1 s 1 -0.449219 1 -1 v -5 c 0 -0.550781 -0.449219 -1 -1 -1 z" fill="${t[red]}"/>
    <path d="m 4.863281 1.941406 c -0.128906 0.015625 -0.253906 0.058594 -0.367187 0.125 c -2.734375 1.582032 -4.074219 4.816406 -3.257813 7.871094 c 0.820313 3.050781 3.59375 5.183594 6.75 5.1875 c 3.160157 0.003906 5.941407 -2.121094 6.765625 -5.167969 c 0.828125 -3.050781 -0.5 -6.289062 -3.230468 -7.878906 c -0.476563 -0.28125 -1.089844 -0.121094 -1.367188 0.359375 c -0.132812 0.226562 -0.171875 0.5 -0.105469 0.757812 c 0.070313 0.257813 0.234375 0.476563 0.464844 0.609376 c 1.957031 1.140624 2.902344 3.441406 2.3125 5.628906 c -0.59375 2.183594 -2.570313 3.695312 -4.832031 3.691406 c -2.265625 -0.003906 -4.238282 -1.519531 -4.824219 -3.707031 s 0.363281 -4.488281 2.324219 -5.621094 c 0.476562 -0.277344 0.640625 -0.886719 0.363281 -1.363281 c -0.132813 -0.230469 -0.347656 -0.398438 -0.605469 -0.464844 c -0.125 -0.035156 -0.257812 -0.042969 -0.390625 -0.027344 z m 0 0" fill="${t[red]}"/>
</svg>
