    # Restart icon — circular arrow (uses yellow)
    cat > "$WLOGOUT_ICON_DIR/restart.svg" << IEOF
<svg height="16px" viewBox="0 0 16 16" width="16px" xmlns="http://www.w3.org/2000/svg">
    <path d="m 8 1 c -3.859375 0 -7 3.140625 -7 7 s 3.140625 7 7 7 c 3.527344 0 6.46875 -2.617188 6.929688 -6.03125 c -0.304688 0.621094 -0.945313 1.03125 -1.679688 1.03125 c -1.023438 0 -1.875 -0.851562 -1.875 -1.875 c 0 -0.265625 0.054688 -0.515625 0.152344 -0.742188 c -0.703125 0.9375 -1.820313 1.542188 -3.074219 1.542188 c -2.140625 0 -3.875 -1.734375 -3.875 -3.875 s 1.734375 -3.875 3.875 -3.875 c 0.28125 0 0.554688 0.03125 0.816406 0.085938 c -0.363281 -0.214844 -0.789062 -0.335938 -1.246094 -0.335938" fill="none" stroke="${t[yellow]}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
