# ── Apply theme to wlogout CSS ──────────────────────────────────────────────
apply_wlogout() {
    local -n t="$1"

    # Generate per-theme colored SVG icons
    gen_wlogout_icons "$1"

    cat > "$WLOGOUT_CSS" << WLOGOUT_EOF
/* Auto-generated by niri-theme — ${1} */
* {
    background-image: none;
    box-shadow: none;
}

window {
    background-color: $(hex_to_rgba "${t[bg]}" 0.92);
    font-family: "JetBrains Mono", "monospace";
    font-size: 14px;
}

button {
    background-color: ${t[bg_alt]};
    color: ${t[fg]};
    border: 2px solid ${t[bg_dark]};
    border-radius: 16px;
    margin: 12px;
    padding: 24px;
    background-repeat: no-repeat;
    background-position: center;
    background-size: 28%;
    transition: all 200ms ease;
}

button:hover {
    background-color: ${t[bg_dark]};
    border-color: ${t[accent]};
    color: ${t[accent]};
}

button:active {
    background-color: ${t[accent]};
    color: ${t[bg]};
    border-color: ${t[accent]};
}

button:focus {
    outline-style: none;
}

#lock {
    background-image: image(url("${WLOGOUT_ICON_DIR}/lock.svg"));
}
#lock:hover {
    border-color: ${t[blue]};
    color: ${t[blue]};
}

#logout {
    background-image: image(url("${WLOGOUT_ICON_DIR}/logout.svg"));
}
#logout:hover {
    border-color: ${t[accent]};
    color: ${t[accent]};
}

#shutdown {
    background-image: image(url("${WLOGOUT_ICON_DIR}/shutdown.svg"));
}
#shutdown:hover {
    border-color: ${t[red]};
    color: ${t[red]};
}
#shutdown:active {
    background-color: ${t[red]};
    color: ${t[bg]};
}

#restart {
    background-image: image(url("${WLOGOUT_ICON_DIR}/restart.svg"));
}
#restart:hover {
    border-color: ${t[yellow]};
    color: ${t[yellow]};
}

#suspend {
    background-image: image(url("${WLOGOUT_ICON_DIR}/suspend.svg"));
}
#suspend:hover {
    border-color: ${t[green]};
    color: ${t[green]};
}

#hibernate {
    background-image: image(url("${WLOGOUT_ICON_DIR}/hibernate.svg"));
}
#hibernate:hover {
    border-color: ${t[purple]};
    color: ${t[purple]};
}
WLOGOUT_EOF
}

# ── Apply theme to gsettings (GTK, icons, color scheme) ─────────────────────
apply_gsettings() {
    local -n t="$1"

    gsettings set org.gnome.desktop.interface gtk-theme "${t[gtk_theme]}"
    gsettings set org.gnome.desktop.interface icon-theme "${t[icon_theme]}"
    gsettings set org.gnome.desktop.interface color-scheme "prefer-dark"
    gsettings set org.gnome.desktop.interface cursor-theme "${t[cursor]}"
    gsettings set org.gnome.desktop.interface accent-color "${t[accent_color]}"
}

# ── Apply wallpaper ──────────────────────────────────────────────────────────
apply_wallpaper() {
    local -n t="$1"
    local wp_dir="$WALLPAPER_DIR/${t[wallpaper_dir]}"
    local state_file="$HOME/.cache/niri-theme-wallpaper-state"

    if [ ! -d "$wp_dir" ]; then
        echo "WARNING: wallpaper directory $wp_dir not found, skipping"
        return
    fi

    # List all image files in the theme directory
    local wallpapers=()
    while IFS= read -r line; do
        wallpapers+=("$line")
    done < <(find -L "$wp_dir" -maxdepth 1 -type f \( -name '*.png' -o -name '*.jpg' \) -print | sort)

    if [ ${#wallpapers[@]} -eq 0 ]; then
        echo "WARNING: no wallpapers found in $wp_dir, skipping"
        return
    fi

    # Pick the next wallpaper in sequence (cycling through all)
    local last_used=""
    if [ -f "$state_file" ]; then
        last_used=$(grep "^${t[wallpaper_dir]}=" "$state_file" 2>/dev/null | cut -d= -f2- || true)
    fi

    local wp=""
    if [ ${#wallpapers[@]} -eq 1 ]; then
        wp="${wallpapers[0]}"
    else
        # Find the index of the last-used wallpaper, pick the next one
        local next_idx=0
        if [ -n "$last_used" ]; then
            for i in "${!wallpapers[@]}"; do
                if [ "${wallpapers[$i]}" = "$last_used" ]; then
                    next_idx=$(( (i + 1) % ${#wallpapers[@]} ))
                    break
                fi
            done
        fi
        wp="${wallpapers[$next_idx]}"
    fi

    # Save state
    mkdir -p "$(dirname "$state_file")"
    if grep -q "^${t[wallpaper_dir]}=" "$state_file" 2>/dev/null; then
        sed -i "s|^${t[wallpaper_dir]}=.*|${t[wallpaper_dir]}=$wp|" "$state_file"
    else
        echo "${t[wallpaper_dir]}=$wp" >> "$state_file"
    fi

    # Kill existing swaybg (match the binary name exactly)
    pkill -x swaybg 2>/dev/null || true
    sleep 0.3

    # Start new swaybg fully detached from this script
    setsid /usr/bin/swaybg -i "$wp" -m fill >/dev/null 2>&1 &

    # Update niri config spawn-at-startup line to match the selected wallpaper
    if grep -q 'spawn-at-startup "swaybg"' "$NIRI_CONFIG" 2>/dev/null; then
        sed -i "s|spawn-at-startup \"swaybg\".*|spawn-at-startup \"swaybg\" \"-i\" \"$wp\" \"-m\" \"fill\"|" "$NIRI_CONFIG"
    fi

    echo "  (wallpaper: $(basename "$wp"))"
}

# ── Apply theme to TTY/vtrgb ────────────────────────────────────────────────
apply_vtrgb() {
    local -n t="$1"
    local vtrgb_file="/etc/vtrgb-${t[vtrgb]}"

    if [ ! -f "$vtrgb_file" ]; then
        echo "  WARNING: vtrgb file $vtrgb_file not found, skipping"
        return
    fi

    # Copy the palette file and apply it
    sudo -n cp "$vtrgb_file" /etc/vtrgb 2>/dev/null && \
        sudo -n setvtrgb /etc/vtrgb 2>/dev/null || \
        echo "  WARNING: could not apply vtrgb (needs sudo)"
}

# ── Apply theme to nvim ─────────────────────────────────────────────────────
apply_nvim() {
    local -n t="$1"
    local nvim_theme_file="$CONFIG_DIR/nvim/lua/theme.lua"

    mkdir -p "$(dirname "$nvim_theme_file")"
    cat > "$nvim_theme_file" << NVIM_EOF
-- This file is auto-generated by niri-theme — do not edit manually
return { colorscheme = "${t[nvim_scheme]}" }
NVIM_EOF
}

# ── Apply theme to micro ────────────────────────────────────────────────────
apply_micro() {
    local -n t="$1"
    local micro_config="$CONFIG_DIR/micro/settings.json"
    mkdir -p "$(dirname "$micro_config")"
    cat > "$micro_config" << MICRO_EOF
{
    "colorscheme": "${t[micro_scheme]}",
    "mkparents": true,
    "softwrap": true,
    "tabsize": 4,
    "tabstospaces": true
}
MICRO_EOF
}

# ── Apply theme to nano ─────────────────────────────────────────────────────
apply_nano() {
    local -n t="$1"
    local nanorc="$HOME/.nanorc"
    local nano_theme_file="$CONFIG_DIR/nano/${t[nano_theme]}.nanorc"

    # Include syntax highlighting from /usr/share/nano
    cat > "$nanorc" << NANO_EOF
## Auto-generated by niri-theme — do not edit manually
## Active theme: ${t[nano_theme]}

## Load syntax highlighting for all supported languages
include "/usr/share/nano/*.nanorc"

## Theme colors
include "$nano_theme_file"
NANO_EOF
}

# ── Apply theme to bat (better cat) ────────────────────────────────────────
apply_bat() {
    local -n t="$1"
    local bat_config="$CONFIG_DIR/bat/config"
    mkdir -p "$(dirname "$bat_config")"
    cat > "$bat_config" << BAT_EOF
# Auto-generated by niri-theme — do not edit manually
--theme="${t[bat_theme]}"
--style="numbers,changes,header"
--paging="never"
BAT_EOF
}

# ── Apply theme to SwayOSD ──────────────────────────────────────────────────
apply_swayosd() {
    local -n t="$1"
    local swayosd_css="/etc/xdg/swayosd/style.css"

    # SwayOSD uses GTK CSS with @theme references, so we write a custom
    # style sheet that matches the active theme colors
    sudo -n tee "$swayosd_css" > /dev/null << SWAYOSD_EOF
/* Auto-generated by niri-theme — do not edit manually */
window#osd {
  border-radius: 12px;
  border: 2px solid ${t[accent]};
  background: ${t[bg]};
}
window#osd #container {
  margin: 12px;
}
window#osd image,
window#osd label {
  color: ${t[fg]};
}
window#osd progressbar:disabled,
window#osd image:disabled {
  opacity: 0.5;
}
window#osd progressbar,
window#osd segmentedprogress {
  min-height: 6px;
  border-radius: 999px;
  background: transparent;
  border: none;
}
window#osd trough,
window#osd segment {
  min-height: inherit;
  border-radius: inherit;
  border: none;
  background: ${t[bg_alt]};
}
window#osd progress,
window#osd segment.active {
  min-height: inherit;
  border-radius: inherit;
  border: none;
  background: ${t[accent]};
}
SWAYOSD_EOF
}

# ── Main ────────────────────────────────────────────────────────────────────
main() {
    if [ $# -eq 0 ]; then
        echo "Usage: niri-theme <theme-name>"
        echo "Themes: $THEME_NAMES"
        echo "  (partial matches allowed: gruvbox, catppuccin, mocha, nord, tokyo)"
        echo ""
        echo "Current themes available:"
        for name in $THEME_NAMES; do
            echo "  - $name"
        done
        return 1
    fi

    local theme_var
    theme_var=$(get_theme "$1") || {
        echo "ERROR: unknown theme '$1'"
        echo "Available: $THEME_NAMES"
        return 1
    }

    echo "Switching to theme: $theme_var"

    # Apply to all components
    echo "  niri config..."
    apply_niri "$theme_var"

    echo "  wezterm..."
    apply_wezterm "$theme_var"

    echo "  waybar..."
    apply_waybar "$theme_var"

    echo "  fuzzel..."
    apply_fuzzel "$theme_var"

    echo "  mako..."
    apply_mako "$theme_var"

    echo "  swaylock..."
    apply_swaylock "$theme_var"

    echo "  wlogout..."
    apply_wlogout "$theme_var"

    echo "  gsettings (GTK/icons/cursor/accent)..."
    apply_gsettings "$theme_var"

    echo "  wallpaper..."
    apply_wallpaper "$theme_var"

    echo "  TTY/vtrgb..."
    apply_vtrgb "$theme_var"

    echo "  nvim..."
    apply_nvim "$theme_var"

    echo "  micro..."
    apply_micro "$theme_var"

    echo "  nano..."
    apply_nano "$theme_var"

    echo "  bat..."
    apply_bat "$theme_var"

    echo "  SwayOSD..."
    apply_swayosd "$theme_var"

    # Reload mako
    makoctl reload 2>/dev/null || true

    # Restart waybar (full restart needed for config changes)
    pkill -x waybar 2>/dev/null || true
    sleep 0.3
    setsid /usr/bin/waybar >/dev/null 2>&1 &

    # Reload SwayOSD if running
    pkill -x swayosd-server 2>/dev/null || true
    sleep 0.2
    setsid /usr/bin/swayosd-server >/dev/null 2>&1 &

    # Notify
    notify-send -a "niri-theme" "Theme Switched" "Applied $theme_var" 2>/dev/null || true

    echo ""
    echo "Done. Theme '$theme_var' applied."
    echo "wezterm will pick up the change on next config reload (Ctrl+Shift+R or restart)."
    echo "niri config will reload automatically (live config)."
    echo "nvim will pick up the theme on next launch."
    echo "micro and nano will pick up the theme on next launch."
    echo "bat will pick up the theme immediately (reads config on each invocation)."
    echo "TTY colors applied immediately (active TTYs + future logins)."
}

main "$@"